    "Lifecycle": {
      "description": "The frozen two-stage lifecycle. Stage 1 computes `b0_pre_spec_hash` over the normative protocol and Stage-1 inputs; guests then embed that hash and their closure (guest-set hash, identities, populated allowlist) is derived afterwards, at R0 time.",
      "type": "object",
      "required": [
        "note",
        "post_spec_hash_steps",
        "stage1_spec_hash_excludes",
        "stage1_spec_hash_includes"
      ],
      "properties": {
        "note": {
          "type": "string"
        },
        "post_spec_hash_steps": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stage1_spec_hash_excludes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stage1_spec_hash_includes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "LocalResourceBudget": {
      "description": "A recommended default resource-budget an operator may configure per device. Not consensus, proof validity, candidate selection, or hardware eligibility.",
      "type": "object",
      "required": [
        "default_fraction_percent",
        "scope"
      ],
      "properties": {
        "default_fraction_percent": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
