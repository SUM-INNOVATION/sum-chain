            "$ref": "#/definitions/OfficialStatement"
          }
        }
      },
      "additionalProperties": false
    },
    "PendingInputs": {
      "description": "Typed placeholders for the **Stage-1** implementation-produced fields that must exist before `b0_pre_spec_hash` can be computed. Exactly three categories: candidate container digests (base + per-architecture builder), candidate dependency lock hashes, and candidate verifier-material manifests.\n\nPost-spec-hash guest closure (`r0_guest_set_hash`, guest-program / image / vkey identities, populated `GuestProgramAllowlistV1`) is deliberately NOT here: guests embed the finalized spec hash, so their identities cannot be a spec-hash input without circularity. There is no field capable of accepting a guest identity or the guest-set hash.\n\nEvery field is absent in the committed artifact (omitted, never `null`); no fabricated or temporary values are ever written here.",
      "type": "object",
      "properties": {
        "candidate_container_digests": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/ContainerDigest"
          }
        },
        "cargo_lock_hashes": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/LockHash"
          }
        },
        "verifier_material_manifests": {
          "type": [
            "array",
            "null"
          ],
          "items": {
            "$ref": "#/definitions/VerifierMaterialManifestRef"
          }
        }
      },
      "additionalProperties": false
    },
    "QualificationCriteria": {
      "description": "What a candidate qualifies on, and what can never disqualify it. Prover performance and device resources are reported-only and appear in `never_disqualifies`.",
      "type": "object",
      "required": [
        "never_disqualifies",
        "note",
        "qualifies_on"
      ],
      "properties": {
        "never_disqualifies": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "note": {
          "type": "string"
        },
        "qualifies_on": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "QualificationGates": {
      "description": "Chain-side proof-verification qualification, under a controlled reference envelope (a configured cpuset / memory limit). These are performance gates, not hardware-class gates: neither validators nor contributors have a CPU/RAM minimum. `reference_cpuset_cores` / `reference_memory_bytes` are the configured candidate-comparison envelope, never a deployment or consensus hardware minimum. Insufficient performance is an operational-liveness condition, not a consensus / proof-system disqualification.",
      "type": "object",
      "required": [
        "aggregate_verify_budget_ns_per_block",
        "gates",
        "max_cycles",
        "reference_cpuset_cores",
        "reference_memory_bytes",
        "scope",
        "validator_eligibility",
        "verifier_material_bytes",
        "verify_p99_gate_ns"
      ],
      "properties": {
        "aggregate_verify_budget_ns_per_block": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "gates": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "max_cycles": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "reference_cpuset_cores": {
          "type": "integer",
          "format": "uint32",
          "minimum": 0.0
        },
        "reference_memory_bytes": {
          "type": "integer",
          "format": "uint64",
          "minimum": 0.0
        },
        "scope": {
          "type": "string"
        },
        "validator_eligibility": {
