# Build artifacts
/target/
**/*.rs.bk

# IDE
.idea/
.vscode/
*.swp
*.swo

# Data directories
/data/
/keys/

# /genesis/ holds both committed templates (chain_id, validators, alloc — no
# key material) and operator-rendered runtime files. Ignore everything by
# default and re-include only the templates we deliberately track. Switched
# from `/genesis/` (dir ignore) to `/genesis/*` (file pattern) so per-file
# `!` exceptions actually take effect — git does not descend into a fully-
# excluded directory.
/genesis/*
!/genesis/local_genesis.json
!/genesis/mainnet_genesis.json
!/genesis/testnet_genesis.json
!/genesis/snip-mirror-genesis.template.json

# OS files
.DS_Store
Thumbs.db

# Node.js
node_modules/
dist/
.next/
out/
SNIP-V2-CHAIN-PLAN.md
SNIP-V2-TESTNET-DEPLOYMENT-PREP.md
SNIP-V2-RPC-CHEATSHEET.md

.claude/